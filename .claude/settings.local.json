{
  "permissions": {
    "allow": [
      "Bash(dotnet:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet ef:*)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(node --check:*)",
      "Bash(python:*)",
      "Bash(py:*)",
      "Bash(python.exe:*)",
      "Bash(python3:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(where:*)",
      "Bash(find:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(test:*)",
      "Bash(bash:*)",
      "Bash(cat:*)",
      "Bash(more:*)",
      "Bash(sed:*)",
      "Bash(xargs:*)",
      "Bash(netstat:*)",
      "Bash(findstr:*)",
      "Bash(tasklist:*)",
      "Bash(powershell -Command:*)",
      "Bash(gh:*)",
      "Bash(csharp-ls:*)",
      "Bash(claude:*)",
      "Bash(claude mcp:*)",
      "Bash(chmod +x:*)",
      "Bash(export:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:markdown.new)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:docs.microsoft.com)",
      "WebFetch(domain:www.telerik.com)",
      "WebFetch(domain:www.builder.io)",
      "WebFetch(domain:vuejs.org)",
      "WebFetch(domain:antdv.com)",
      "WebFetch(domain:www.antdv.com)",
      "WebFetch(domain:pinia.vuejs.org)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:vitejs.dev)",
      "WebFetch(domain:doc.vben.pro)",
      "mcp__filesystem__list_directory",
      "mcp__filesystem__list_directory_with_sizes",
      "mcp__filesystem__directory_tree",
      "mcp__filesystem__read_text_file",
      "mcp__filesystem__read_multiple_files",
      "mcp__filesystem__edit_file",
      "mcp__filesystem__write_file",
      "mcp__filesystem__create_directory",
      "mcp__filesystem__move_file",
      "mcp__filesystem__search_files",
      "mcp__filesystem__list_allowed_directories",
      "mcp__sequential-thinking__sequentialthinking",
      "mcp__memory__create_entities",
      "mcp__memory__create_relations",
      "mcp__memory__add_observations",
      "mcp__ide__getDiagnostics",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "EnterWorktree",
      "ExitWorktree"
    ],
    "deny": [
      "Bash(git add .)",
      "Bash(git add -A)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "filesystem",
    "memory",
    "sequential-thinking"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-start.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-compact.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/on-stop.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/workflow-orchestrator.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write|mcp__filesystem__edit_file|mcp__filesystem__write_file|mcp__filesystem__move_file",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-edit-check.mjs",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-bash-check.mjs",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-exit-plan-check.mjs",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-agent-gate-check.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-agent-verify.mjs",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write|mcp__filesystem__edit_file|mcp__filesystem__write_file",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-build.mjs",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "outputStyle": "Explanatory"
}
